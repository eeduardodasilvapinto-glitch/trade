{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "volumes": {
    "data": {
      "mountPath": "/app/data",
      "description": "Persistencia de dados OHLCV, estatisticas e relatorios"
    }
  },
  "variables": {
    "RAILWAY_RUN_UID": "0",
    "YH_SYMBOL": "^BVSP",
    "YH_SYMBOL_ALT": "MES=F",
    "ALPHA_VANTAGE_KEY": "",
    "AV_SYMBOL": "^BVSP"
  }
}
